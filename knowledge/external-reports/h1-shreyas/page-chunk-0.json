49a3-87f9-6c792369b1e2","crdt_format_version":1,"crdt_data":{"title":{"r":"YUV-g9ki9TKXQTKQy6RI1A,\"start\",\"end\"","n":{"YUV-g9ki9TKXQTKQy6RI1A,\"start\",\"end\"":{"s":{"x":"YUV-g9ki9TKXQTKQy6RI1A","i":[{"t":"s"},{"t":"t","i":["7brC1A9JHvOY",1],"o":"start","l":42,"c":"H1 Report Notes - Shreyas Chavhan (Shared)"},{"t":"e"}],"l":""},"c":[]}}}}},"role":"comment_only"}},"fe8a075b-6146-4a25-9a58-1e97a25661ab":{"spaceId":"2799f4f2-7e28-49a3-87f9-6c792369b1e2","value":{"role":"none"}},"3f554d0d-6fc7-453a-ad8f-d177b5c03135":{"value":{"value":{"id":"3f554d0d-6fc7-453a-ad8f-d177b5c03135","version":73,"type":"header","properties":{"title":[["Note:"]]},"format":{"use_crdt":false,"toggleable":false},"created_time":1709533477492,"last_edited_time":1709533522562,"parent_id":"c2c9e990-d247-4d28-8626-da2604bd4498","parent_table":"block","alive":true,"created_by_table":"notion_user","created_by_id":"4170139b-d558-45a4-b4a7-0eac5d7eda55","last_edited_by_table":"notion_user","last_edited_by_id":"4170139b-d558-45a4-b4a7-0eac5d7eda55","space_id":"2799f4f2-7e28-49a3-87f9-6c792369b1e2","crdt_format_version":1,"crdt_data":{"title":{"r":"k-1t5xDcMw7hdG6rsOfFQQ,\"start\",\"end\"","n":{"k-1t5xDcMw7hdG6rsOfFQQ,\"start\",\"end\"":{"s":{"x":"k-1t5xDcMw7hdG6rsOfFQQ","i":[{"t":"s"},{"t":"t","i":["xERjxeLLk84B",1],"o":"start","l":5,"c":"Note:"},{"t":"e"}],"l":""},"c":[]}}}}},"role":"comment_only"}},"12164b9c-9cb9-446c-9e42-a1124b3f8aa9":{"value":{"value":{"id":"12164b9c-9cb9-446c-9e42-a1124b3f8aa9","version":2592,"type":"code","properties":{"title":[["## Note\n\nA few weeks back I shared a post on twitter saying that I have read **5000** H1 reports in past two months, here: https://twitter.com/shreyas_chavhan/status/1763031109753794835\n\nA few of you guys asked me to share the notes I took. I absolutely don't find it wrong to share my notes with you guys but I'm not extremely sure if you'll find it helpful and if you do - to what degree because I didn't create these notes considering that I'll have to make it public one day. It was for my personal use and hence it's completely messy and unstructured. \n\nI know what I have written and why and how'll I be able to use it but I understand that it can get difficult for you guys to understand how you're going to use it. It also doesn't have all 5000 reports that I read and only contain reports I thought I'll find valuable based on who I'm, how I hunt and how much I already knew.\n\nIt's on you how'll you leverage it and make use of it. I'm just making it public. I'll be very happy if you'll find it worth and valuable - but if not, just remember that it wasn't meant to be made public when I made these notes."]],"language":[["Markdown"]]},"format":{"use_crdt":false,"code_wrap":true},"created_time":1709532415345,"last_edited_time":1709535976621,"parent_id":"c2c9e990-d247-4d28-8626-da2604bd4498","parent_table":"block","alive":true,"created_by_table":"notion_user","created_by_id":"4170139b-d558-45a4-b4a7-0eac5d7eda55","last_edited_by_table":"notion_user","last_edited_by_id":"4170139b-d558-45a4-b4a7-0eac5d7eda55","space_id":"2799f4f2-7e28-49a3-87f9-6c792369b1e2","crdt_format_version":1,"crdt_data":{"title":{"r":"cfXBPbUEhnQxtENL3HKEZw,\"start\",\"end\"","n":{"cfXBPbUEhnQxtENL3HKEZw,\"start\",\"end\"":{"s":{"x":"cfXBPbUEhnQxtENL3HKEZw","i":[{"t":"s"},{"t":"t","i":["zGRKKLN3rkT_",1],"o":"start","l":1115,"c":"## Note\n\nA few weeks back I shared a post on twitter saying that I have read **5000** H1 reports in past two months, here: https://twitter.com/shreyas_chavhan/status/1763031109753794835\n\nA few of you guys asked me to share the notes I took. I absolutely don't find it wrong to share my notes with you guys but I'm not extremely sure if you'll find it helpful and if you do - to what degree because I didn't create these notes considering that I'll have to make it public one day. It was for my personal use and hence it's completely messy and unstructured. \n\nI know what I have written and why and how'll I be able to use it but I understand that it can get difficult for you guys to understand how you're going to use it. It also doesn't have all 5000 reports that I read and only contain reports I thought I'll find valuable based on who I'm, how I hunt and how much I already knew.\n\nIt's on you how'll you leverage it and make use of it. I'm just making it public. I'll be very happy if you'll find it worth and valuable - but if not, just remember that it wasn't meant to be made public when I made these notes."},{"t":"e"}],"l":""},"c":[]}}}}},"role":"comment_only"}},"62785b5c-1d2d-497e-8fcc-ba4bf0370857":{"value":{"value":{"id":"62785b5c-1d2d-497e-8fcc-ba4bf0370857","version":87,"type":"text","properties":{"title":[["List of 10,000 H1 Reports Collected: "],["‣",[["eoi","add894f1-1d5e-4517-80a5-200aa8a212c2"]]],[" "]]},"format":{"use_crdt":false},"created_time":1709534849809,"last_edited_time":1709534881013,"parent_id":"c2c9e990-d247-4d28-8626-da2604bd4498","parent_table":"block","alive":true,"created_by_table":"notion_user","created_by_id":"4170139b-d558-45a4-b4a7-0eac5d7eda55","last_edited_by_table":"notion_user","last_edited_by_id":"4170139b-d558-45a4-b4a7-0eac5d7eda55","space_id":"2799f4f2-7e28-49a3-87f9-6c792369b1e2","crdt_format_version":1,"crdt_data":{"title":{"r":"GJkIMwP2nonTtMkFbuOoGg,\"start\",\"end\"","n":{"GJkIMwP2nonTtMkFbuOoGg,\"start\",\"end\"":{"s":{"x":"GJkIMwP2nonTtMkFbuOoGg","i":[{"t":"s"},{"t":"t","i":["7deQcdd3OSYc",1],"o":"start","l":37,"c":"List of 10,000 H1 Reports Collected: "},{"t":"t","i":["7deQcdd3OSYc",38],"o":["7deQcdd3OSYc",37],"l":1,"c":"‣","b":[{"t":"a","x":"GJkIMwP2nonTtMkFbuOoGg","l":"","i":["7deQcdd3OSYc",40],"s":{"i":["7deQcdd3OSYc",38],"a":"b"},"e":{"i":["7deQcdd3OSYc",38],"a":"a"},"a":["eoi","add894f1-1d5e-4517-80a5-200aa8a212c2"]}],"a":[]},{"t":"t","i":["7deQcdd3OSYc",39],"o":["7deQcdd3OSYc",38],"l":1,"c":" "},{"t":"e"}],"l":""},"c":[]}}}}},"role":"comment_only"}},"b901fe7b-d252-4688-8128-30f2cddb6f91":{"value":{"value":{"id":"b901fe7b-d252-