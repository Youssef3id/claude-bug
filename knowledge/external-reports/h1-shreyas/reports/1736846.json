:[],"singular_disclosure_disabled":true,"disclosed_at":"2022-12-16T11:08:50.958Z","bug_reporter_agreed_on_going_public_at":"2022-12-16T02:17:17.644Z","team_member_agreed_on_going_public_at":"2022-12-16T11:08:50.812Z","comments_closed?":false,"facebook_team?":false,"team_private?":false,"vulnerability_information":"","weakness":{"id":22,"name":"Storing Passwords in a Recoverable Format"},"original_report_id":null,"original_report_url":null,"attachments":[],"allow_singular_disclosure_at":null,"vote_count":16,"voters":["jumpydata","zy9ard3","ahmadmujtaba","shreyaschavhan","shubham_srt","pr0f0x01","hunterr0x01","shivammusic","0x0days","wazzap007","and 6 more..."],"severity":{"rating":"low","author_type":"Team"},"structured_scope":{"databaseId":61325,"asset_type":"URL","asset_identifier":"akismet.com","max_severity":"critical"},"abilities":{"assignable_team_members":[],"assignable_team_member_groups":[]},"is_exploit_agent_supported?":false,"is_linear_agent_ui_supported?":false,"summaries":[{"id":231040,"category":"team","content":"We have switched to sending the Akismet API key as part of the request body by default.","updated_at":"2022-12-16T11:08:43.182Z","can_view?":true,"can_create?":false,"attachments":[],"user":{"id":733677,"username":"ehtis","name":"Ehtisham","bio":"","cleared":false,"verified":false,"website":null,"location":"","created_at":"2019-09-05T15:13:14.638Z","url":"https://hackerone.com/ehtis","hackerone_triager":false,"hackerone_employee":false,"user_type":"company","profile_picture_urls":{"small":"/assets/avatars/default-14ffa99f59cd01423c64904352cc130ffcb6a802eadfd11777a54485749e60f2.png","medium":"/assets/avatars/default-14ffa99f59cd01423c64904352cc130ffcb6a802eadfd11777a54485749e60f2.png","xtralarge":"/assets/avatars/default-14ffa99f59cd01423c64904352cc130ffcb6a802eadfd11777a54485749e60f2.png"}}},{"id":231006,"category":"researcher","content":"At the time of this report, Akismet API keys used formed part of the subdomain request to Akismet’s backend in the form `api-key.rest.akismet.com`. This means that the API key is transmitted over DNS - a protocol that is [well known for its lack of encryption](https://developers.cloudflare.com/1.1.1.1/encryption/). \n\nAs a result, Akismet API keys cannot be considered secure or private. Anyone capturing network packets, or the DNS server operator for example, could easily log the DNS requests - and therefore API key - from a client accessing the Akismet API.\n\nThe unwanted disclosure of the API key could cause Denial of Service or Information Leakage should a malicious actor get hold of it.","updated_at":"2022-12-16T02:30:35.564Z","can_view?":true,"can_create?":false,"attachments":[],"user":{"id":419083,"username":"aaroncarson","name":"Aaron Carson","bio":"","cleared":false,"verified":false,"website":"https://www.aaroncarson.co.uk","location":"London, UK","created_at":"2018-11-27T13:12:47.513Z","url":"https://hackerone.com/aaroncarson","hackerone_triager":false,"hackerone_employee":false,"user_type":"hacker","profile_picture_urls":{"small":"https://hackerone-us-west-2-production-attachments.s3.us-west-2.amazonaws.com/variants/gydo8km2bnp8ftv81juacjqrasey/c8a1698ff707a5e3e8a91a3484838363845daac68cb82c86d55c9e2d44d67b67?response-content-disposition=inline%3B%20filename%3D%22Me%20LdnBridge%20_smaller.jpeg%22%3B%20filename%2A%3DUTF-8%27%27Me%2520LdnBridge%2520_smaller.jpeg\u0026response-content-type=image%2Fjpeg\u0026X-Amz-Algorithm=AWS4-HMAC-SHA256\u0026X-Amz-Credential=ASIAQGK6FURQR74TRNYO%2F20260429%2Fus-west-2%2Fs3%2Faws4_request\u0026X-Amz-Date=20260429T074502Z\u0026X-Amz-Expires=3600\u0026X-Amz-Security-Token=IQoJb3JpZ2luX2VjECcaCXVzLXdlc3QtMiJHMEUCIAfKpPGxBoXd8MOT%2Baxze%2FpDmeE1WesQmbLVJdaSloUiAiEAuLrLerWj%2FS4pHyjQG4p3QcFBJLNjcWCekmlQOPvek%2F4quwUI7%2F%2F%2F%2F%2F%2F%2F%2F%2F%2F%2FARADGgwwMTM2MTkyNzQ4NDkiDAf%2BnhlTE83ygsAK8yqPBbTDrLeKDqzFWZhq9N395a2yYP%2FhP2hsKxJS8Lzp7AGtEEzFklwUXNpf1W3zf%2B2IBCFfV3W8dQwyAEZa1277H5luSAnlqi%2BGS5fEM9ITx82ZZDYbElagAeBONmXbM50Lv2QVq2