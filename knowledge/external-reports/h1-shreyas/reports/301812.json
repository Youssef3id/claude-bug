"type":"image/png","moderated":null}],"allow_singular_disclosure_at":"2018-10-18T14:28:26.267Z","allow_singular_disclosure_after":-237577574.76992103,"singular_disclosure_allowed":true,"vote_count":90,"voters":["arist0phanes","qiaoqiao","ganeshbagaria","d0xing","jensec","drsniper","osman1337","ertugrul","sklnhunt","shreyaschavhan","and 80 more..."],"severity":{"rating":"medium","author_type":"Team"},"structured_scope":null,"abilities":{"assignable_team_members":[],"assignable_team_member_groups":[]},"is_exploit_agent_supported?":false,"is_linear_agent_ui_supported?":false,"summaries":[{"id":73264,"category":"team","content":"The Bitmoji rendering service provided directory listings and access to .jar and .class files in some of those directories. Although the top level site returned a `403 Forbidden`, the access control check was not present on subpaths, allowing directory listings, notably at `/WEB-INF/` and `/META-INF/`.\n\nWhile not arbitrary file system access on the rendering service, it did provide a directory listing and access to some sensitive files. We thank the reporter for pointing us to this issue.","updated_at":"2021-07-31T00:20:08.183Z","can_view?":true,"can_create?":false,"attachments":[],"user":{"id":139654,"username":"jww-sc","name":"Joel Weinberger","bio":"","cleared":false,"verified":false,"website":null,"location":"","created_at":"2017-02-01T03:04:17.835Z","url":"https://hackerone.com/jww-sc","hackerone_triager":false,"hackerone_employee":false,"user_type":"company","profile_picture_urls":{"small":"/assets/avatars/default-14ffa99f59cd01423c64904352cc130ffcb6a802eadfd11777a54485749e60f2.png","medium":"/assets/avatars/default-14ffa99f59cd01423c64904352cc130ffcb6a802eadfd11777a54485749e60f2.png","xtralarge":"/assets/avatars/default-14ffa99f59cd01423c64904352cc130ffcb6a802eadfd11777a54485749e60f2.png"}}},{"category":"researcher","can_view?":true,"can_create?":false}]}