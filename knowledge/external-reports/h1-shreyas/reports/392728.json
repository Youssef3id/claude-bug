7","kilroywashere2"],"severity":{"rating":"low","author_type":"Team"},"structured_scope":null,"abilities":{"assignable_team_members":[],"assignable_team_member_groups":[]},"is_exploit_agent_supported?":false,"is_linear_agent_ui_supported?":false,"summaries":[{"category":"team","can_view?":true,"can_create?":false},{"id":21552,"category":"researcher","content":"Here is one of my first  ( valid ) report as hunter.\n\nI found an easy way, requesting minimal victim interaction execpted the simple fact to click on a link, to crash the victim's host quickly. It was possible throught  a slack URL used for accessing to the Staging environment : `slack://open?devEnv=staging` .  When used, there had no check if a Slack instance was already opened and by hence an infinite number of instances could be started.\nThe result was a quick CPU and RAM overhelmed finally resulting to a sustem's crash.\n\nI provided a simple POC page showing the issue with different levels ( 10 instances, 20, 50, 1à00, 1000 ).","updated_at":"2020-05-06T21:48:54.639Z","can_view?":true,"can_create?":false,"attachments":[],"user":{"id":237671,"username":"freesec","name":"FreeSec","bio":" ","cleared":false,"verified":false,"website":"https://www.freesec.fr","location":"","created_at":"2018-02-01T15:01:13.680Z","url":"https://hackerone.com/freesec","hackerone_triager":false,"hackerone_employee":false,"user_type":"hacker","profile_picture_urls":{"small":"https://hackerone-us-west-2-production-attachments.s3.us-west-2.amazonaws.com/variants/ijsxx0oobhmobk30giywvoa8o77f/235acf2ba808c3a51a94888fb977392c26f8fb0ccf77a81a4546c5e4065c06f1?response-content-disposition=inline%3B%20filename%3D%22freesec4.png%22%3B%20filename%2A%3DUTF-8%27%27freesec4.png\u0026response-content-type=image%2Fpng\u0026X-Amz-Algorithm=AWS4-HMAC-SHA256\u0026X-Amz-Credential=ASIAQGK6FURQVG2TUFA2%2F20260429%2Fus-west-2%2Fs3%2Faws4_request\u0026X-Amz-Date=20260429T084052Z\u0026X-Amz-Expires=3600\u0026X-Amz-Security-Token=IQoJb3JpZ2luX2VjECcaCXV