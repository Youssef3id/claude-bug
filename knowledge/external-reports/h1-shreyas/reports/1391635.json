:true,"disclosed_at":"2022-06-27T16:27:04.939Z","bug_reporter_agreed_on_going_public_at":"2022-03-28T16:56:39.943Z","team_member_agreed_on_going_public_at":"2022-06-27T16:27:04.787Z","comments_closed?":false,"facebook_team?":false,"team_private?":false,"vulnerability_information":"","weakness":{"id":18,"name":"Information Disclosure"},"original_report_id":null,"original_report_url":null,"attachments":[],"allow_singular_disclosure_at":null,"vote_count":36,"voters":["kashsec","achabi7","defenderwww","aboalezz","loaymorad","he4am","eccelevi","bombon","zy9ard3","thruster","and 26 more..."],"severity":{"rating":"medium","score":6.5,"author_type":"Team","metrics":{"attack_vector":"network","attack_complexity":"low","privileges_required":"none","user_interaction":"required","scope":"unchanged","confidentiality":"high","integrity":"none","availability":"none"}},"structured_scope":null,"abilities":{"assignable_team_members":[],"assignable_team_member_groups":[]},"is_exploit_agent_supported?":false,"is_linear_agent_ui_supported?":false,"summaries":[{"id":164760,"category":"team","content":"Cloudflare Deception Armor could be bypassed by using `.avif` extension making Cache deception attack possible on vulnerable origin servers.\nCloudflare Cache Deception Armor uses a Page rule to protect Cloudflare Cache against caching possibly sensitive information. \nThis attack could be performed by tricking a user into clicking a crafted URL (using \"path confusion techniques\") ending with an `.avif` extension which makes Cloudflare edge cache the returned (normally non-cachable) content. An attacker could then retrieve this cached information from Cloudflare's edge.\nThe page rule was improved to better handle .avif formats and the presented bypass is no longer possible.","updated_at":"2022-06-27T16:19:53.781Z","can_view?":true,"can_create?":false,"attachments":[],"user":{"id":1982826,"username":"m0nia","name":"Monika S","bio":"","cleared":false,"verified":false,"website":null,"location":"","created_at":"2021-09-24T07:21:49.521Z","url":"https://hackerone.com/m0nia","hackerone_triager":false,"hackerone_employee":false,"user_type":"company","profile_picture_urls":{"small":"/assets/avatars/default-14ffa99f59cd01423c64904352cc130ffcb6a802eadfd11777a54485749e60f2.png","medium":"/assets/avatars/default-14ffa99f59cd01423c64904352cc130ffcb6a802eadfd11777a54485749e60f2.png","xtralarge":"/assets/avatars/default-14ffa99f59cd01423c64904352cc130ffcb6a802eadfd11777a54485749e60f2.png"}}},{"id":164298,"category":"researcher","content":"I was able to achieve Cache Deception and/ Poisoning to Cloudflare Customers who were using `Cache Deception Armor` Software using `.avif` extension file\n\n\nThis required User interaction, hence the severity set to Medium\n\nSeverity varies, it depends on what the customer was exposing in their responses\n\n e.g.\n\nIf the customer had user's session within the response, Account Takeover was possible\n\nIf I was able to find a XSS on the customer website, Stored XSS was possible\n\n\n\n\n","updated_at":"2022-06-22T02:36:59.468Z","can_view?":true,"can_create?":false,"attachments":[],"user":{"id":1320367,"username":"bombon","name":"","bio":"","cleared":true,"verified":true,"website":null,"location":"United States","created_at":"2020-09-13T00:06:25.969Z","url":"https://hackerone.com/bombon","hackerone_triager":false,"hackerone_employee":false,"user_type":"hacker","profile_picture_urls":{"small":"https://hackerone-us-west-2-production-attachments.s3.us-west-2.amazonaws.com/variants/f3rg2l1asffqs286fqrs8qn1prcm/3cb67cc78dc0cba55b102dd9eca2ee89b206d3e960be830f070583d9070b69ef?response-content-disposition=inline%3B%20filename%3D%22Screenshot_20211123-004623_Twitter.jpg%22%3B%20filename%2A%3DUTF-8%27%27Screenshot_20211123-004623_Twitter.jpg\u0026response-content-type=image%2Fjpeg\u0026X-Amz-Algorithm=AWS4-HMAC-SHA256\u0026X-Amz-Credential=ASIAQGK6FURQTAHEXB7H%2F20260429%2Fus-west-2%2Fs3%2Faws4_request\u0026X-Amz-Date=20260429T075402Z\u