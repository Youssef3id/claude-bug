45Z","comments_closed?":false,"facebook_team?":false,"team_private?":false,"vulnerability_information":"","weakness":{"id":73,"name":"Phishing"},"original_report_id":null,"original_report_url":null,"attachments":[],"allow_singular_disclosure_at":null,"vote_count":36,"voters":["lubak","mokusou","alp","akichia","ali","tess","thalaivar304","akashhamal0x01","0nlymohammed","0xwise","and 26 more..."],"severity":{"rating":"low","author_type":"Team"},"structured_scope":{"databaseId":32088,"asset_type":"APPLE_STORE_APP_ID","asset_identifier":"443904275","max_severity":"critical"},"abilities":{"assignable_team_members":[],"assignable_team_member_groups":[]},"is_exploit_agent_supported?":false,"is_linear_agent_ui_supported?":false,"summaries":[{"id":62017,"category":"team","content":"When navigation to an invalid hostname occurs, the address bar is updated even though the navigation is cancelled. Due to this incorrect timing of updating the address bar and applying URL normalization, it can be recognized as a different hostname from the actual hostname. As a result, attacker may deceive the user to be browsing a legitimate site when the in-app browser is actually on a phishing site.\n\n","updated_at":"2021-07-05T04:57:54.316Z","can_view?":true,"can_create?":false,"attachments":[],"user":{"id":792437,"username":"lee-by","name":"ByoungYunLee","bio":"","cleared":false,"verified":false,"website":null,"location":"","created_at":"2019-10-23T02:30:19.864Z","url":"https://hackerone.com/lee-by","hackerone_triager":false,"hackerone_employee":false,"user_type":"hacker","profile_picture_urls":{"small":"https://profile-photos.hackerone-user-content.com/variants/e7YSYHJbCxRkTMx3w2a92mts/235acf2ba808c3a51a94888fb977392c26f8fb0ccf77a81a4546c5e4065c06f1","medium":"https://profile-photos.hackerone-user-content.com/variants/e7YSYHJbCxRkTMx3w2a92mts/3f1ab5c6a9b6dadada1e6c8121700b884388bd0a43471fee1897a38ce57d0b2c","xtralarge":"https://profile-photos.hackerone-user-content.com/variants/e7YSYHJbCxRkTMx3w2a92mts/d6d8259739a2a4d509639b7804214d057bca547cc3fafe509ec3e3a86321b1d1"}}},{"id":26360,"category":"researcher","content":"In the internal browser of the LINE iOS application, there was a flaw in the implementation of displaying the address bar of HTTP redirect processing. It was improperly normalized by inserting malicious Unicode character into the domain name.\nAs a result, the domain name and the content of the displayed web page did not match, and Address Bar Spoofing was possible.","updated_at":"2021-09-15T04:44:54.297Z","can_view?":true,"can_create?":false,"attachments":[],"user":{"id":151841,"username":"reinforchu","name":"Tsubasa FUJII","bio":"Web security researcher(Japanese)","cleared":false,"verified":false,"website":"https://reinforc.hu","location":"Tokyo","created_at":"2017-03-17T20:38:48.715Z","url":"https://hackerone.com/reinforchu","hackerone_triager":false,"hackerone_employee":false,"user_type":"hacker","profile_picture_urls":{"small":"https://hackerone-us-west-2-production-attachments.s3.us-west-2.amazonaws.com/variants/d74dykwzxrdefgb51chqdwu0wbdz/235acf2ba808c3a51a94888fb977392c26f8fb0ccf77a81a4546c5e4065c06f1?response-content-disposition=inline%3B%20filename%3D%22reinforchu_icon.png%22%3B%20filename%2A%3DUTF-8%27%27reinforchu_icon.png\u0026response-content-type=image%2Fpng\u0026X-Amz-Algorithm=AWS4-HMAC-SHA256\u0026X-Amz-Credential=ASIAQGK6FURQ3AQIHSJL%2F20260429%2Fus-west-2%2Fs3%2Faws4_request\u0026X-Amz-Date=20260429T081042Z\u0026X-Amz-Expires=3600\u0026X-Amz-Security-Token=IQoJb3JpZ2luX2VjECgaCXVzLXdlc3QtMiJGMEQCIBb%2F7ajla8vtEKoWQOIpLCccIvnPW3hcPCb%2FNQRXSZaLAiAxBKUHPk76EJW3ju%2FZ2lhF01Uag6xiXOhG0wxT5DyRuyq7BQjx%2F%2F%2F%2F%2F%2F%2F%2F%2F%2F8BEAMaDDAxMzYxOTI3NDg0OSIMfhI%2BSplPc0JRr%2FSpKo8FWPsymTitguN%2BJgQeNooD7nbXqVsAkFKWCCsIS9Cltbe6vNdjEZioyLXlijo59cDakuLTzTZImnUyBjYIAXDpfDM3vCF67k0ntcCbjJ8BD1sSfEC7uQSMJxUQwLI4RrLTzJrtGAFIT7bdpvcwRGusfErFQiGt%2BeQz%2BxNEub0Yl3nDAvAWyH2bn8CFxs7Sstj%2Fc4u0daTMrBL8%2FpLQ8scNQNxxs7fbpKqj9Fqy3n5LXNxTPW