":[],"singular_disclosure_disabled":false,"disclosed_at":"2017-01-12T18:01:51.363Z","bug_reporter_agreed_on_going_public_at":null,"team_member_agreed_on_going_public_at":"2016-12-13T18:01:32.509Z","comments_closed?":false,"facebook_team?":false,"team_private?":false,"vulnerability_information":"","weakness":{"id":27,"name":"Improper Authentication - Generic"},"original_report_id":null,"original_report_url":null,"attachments":[],"allow_singular_disclosure_at":"2017-01-12T18:01:32.542Z","allow_singular_disclosure_after":-293215107.2139818,"singular_disclosure_allowed":true,"vote_count":15,"voters":["loaymorad","mpz","r3y","eveeez","khizer47","sh3rif0x","mostafamamdoh","japz","0xm1racle","ahmed_abdalla","and 5 more..."],"structured_scope":null,"abilities":{"assignable_team_members":[],"assignable_team_member_groups":[]},"is_exploit_agent_supported?":false,"is_linear_agent_ui_supported?":false,"summaries":[{"id":3096,"category":"team","content":"A security researcher discovered that near-duplicate accounts like attacker@gmail.com, a.ttacker@gmail.com, and attacker+foo@gmail.com were all treated as separate accounts, while some email services, like gmail and google apps, treat these as the same account. This issue could lead to excess email confirmation messages from Legal Robot to a single real email account. If the legitimate user confirmed the email address (as we are all sort of trained to do with email), the attacker's account on Legal Robot would be activated.","updated_at":"2016-12-13T18:01:23.404Z","can_view?":true,"can_create?":false,"attachments":[],"user":{"id":21222,"username":"danrubins","name":"Dan Rubins","bio":"","cleared":false,"verified":false,"website":null,"location":"San Francisco, CA","created_at":"2015-04-28T21:02:56.372Z","url":"https://hackerone.com/danrubins","hackerone_triager":false,"hackerone_employee":false,"user_type":"company","profile_picture_urls":{"small":"https://profile-photos.hackerone-user-content.com/variants/000/021/222/c1d0d51f40