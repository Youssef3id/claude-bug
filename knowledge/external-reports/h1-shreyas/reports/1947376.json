oint to delete any animal from other users' accounts, leading to unauthorized data deletion.","updated_at":"2024-06-25T18:11:03.519Z","can_view?":true,"can_create?":false,"attachments":[],"user":{"id":1467580,"username":"ideborah","name":"Deborah Ingram","bio":"","cleared":false,"verified":false,"website":null,"location":"","created_at":"2021-01-11T15:26:55.497Z","url":"https://hackerone.com/ideborah","hackerone_triager":false,"hackerone_employee":false,"user_type":"hacker","profile_picture_urls":{"small":"https://hackerone-us-west-2-production-attachments.s3.us-west-2.amazonaws.com/variants/vlqtahexr9xtej7w41uff3pi30h2/3cb67cc78dc0cba55b102dd9eca2ee89b206d3e960be830f070583d9070b69ef?response-content-disposition=inline%3B%20filename%3D%22R0e268b9cabd9612c20198b4457076e07.jpg%22%3B%20filename%2A%3DUTF-8%27%27R0e268b9cabd9612c20198b4457076e07.jpg\u0026response-content-type=image%2Fjpeg\u0026X-Amz-Algorithm=AWS4-HMAC-SHA256\u0026X-Amz-Credential=ASIAQGK6FURQTAHEXB7H%2F20260429%2Fus-west-2%2Fs3%2Faws4_request\u0026X-Amz-Date=20260429T073537Z\u0026X-Amz-Expires=3600\u0026X-Amz-Security-Token=IQoJb3JpZ2luX2VjECcaCXVzLXdlc3QtMiJIMEYCIQChIR%2BN97Ch2ix7XsXq17%2B77Aj5srv55nOOIGXGa%2BX9FwIhAO5doc0Y%2F5yo9mdVGdbcxlWv6pUyzfiOBtSliJu4vR95KrsFCPD%2F%2F%2F%2F%2F%2F%2F%2F%2F%2FwEQAxoMMDEzNjE5Mjc0ODQ5IgwhKdItxeukLCgLAXMqjwX1csbEEbsYEcYR3CgqSk%2F%2FO7WPOS1f8BovMknKKU%2Bzns%2BvK4XDWRM9156VksTFyznEoAgaELZWho%2BqZjoptJHOi9LMMCUs7JCXfQathsP2IevjpQ2%2FTpyi6L1yxdDFMvkMGa9frF4YKBnhJlgyCf%2F6EFlM1ZXnrS08iTbRvOnwBCwK2yJxSg%2FFM6Asa43BR81AoMkBZCcu3%2BiH4EfXWpdthSLDyY0JC4iLDVJWtejZvUbINtUF%2FMRUYNfZqUNqfJm5CJLt3hqykHTFtcYZPShjS7qRF%2Bm9mEhG2GoGEHSeHtX3fNt4GxivzEqzxN3ME%2FoGAMVjkZS3tiLnGlWXGmu89Lvhw75PADLMN9qdStsba6777vyBFuIfCVh%2F0n05kJIKPLCOn6Vmpz34%2BEnrnnfhqRheBxTepJ75QWsWgsdl7YTaeFa9LtuWlHzlBpRMerVL1ntX50DR%2FW9LoUcbggZZmwXtAdBGN2NlC%2FlAjVzgbgU82aVCtceIbu3QdCM1Eb45oHEZgJwU%2BCYERADIRmUWdFaYL5FSTDb2vscuEP5Iank6mVq35Ga9nrVHjDfWpq4tjZIZhHj460NvZWqR8yh7ksqdgJ9nrYSOPAe%2B9HjhpCnTcPzA4a5OLAxLpBqv