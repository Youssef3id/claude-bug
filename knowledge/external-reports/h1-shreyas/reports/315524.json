eed_on_going_public_at":"2018-07-06T12:03:33.933Z","comments_closed?":false,"facebook_team?":false,"team_private?":false,"vulnerability_information":"","bounty_amount":"300.0","formatted_bounty":"$300","weakness":{"id":65,"name":"Business Logic Errors"},"original_report_id":null,"original_report_url":null,"attachments":[],"allow_singular_disclosure_at":"2018-07-10T10:14:39.543Z","allow_singular_disclosure_after":-246238558.22667035,"singular_disclosure_allowed":true,"vote_count":20,"voters":["loaymorad","airblender","umfc","ali","mohaned0101","savitar0x01","catferq","povargek","circuit","eveeez","and 10 more..."],"severity":{"rating":"medium","author_type":"User"},"structured_scope":null,"abilities":{"assignable_team_members":[],"assignable_team_member_groups":[]},"is_exploit_agent_supported?":false,"is_linear_agent_ui_supported?":false,"summaries":[{"id":9521,"category":"team","content":"Ошибка в генерации CSRF-токена. ","updated_at":"2018-07-06T12:03:26.525Z","can_view?":true,"can_create?":false,"attachments":[],"user":{"id":58768,"username":"exe","name":"","bio":"","cleared":false,"verified":false,"website":"https://vk.com","location":"","created_at":"2016-03-01T21:12:04.069Z","url":"https://hackerone.com/exe","hackerone_triager":false,"hackerone_employee":false,"user_type":"company","profile_picture_urls":{"small":"https://profile-photos.hackerone-user-content.com/variants/000/058/768/cb3119e614f25ed716db2258fd649c2cd62b29b1_original.png/235acf2ba808c3a51a94888fb977392c26f8fb0ccf77a81a4546c5e4065c06f1","medium":"https://profile-photos.hackerone-user-content.com/variants/000/058/768/cb3119e614f25ed716db2258fd649c2cd62b29b1_original.png/3f1ab5c6a9b6dadada1e6c8121700b884388bd0a43471fee1897a38ce57d0b2c","xtralarge":"https://profile-photos.hackerone-user-content.com/variants/000/058/768/cb3119e614f25ed716db2258fd649c2cd62b29b1_original.png/d6d8259739a2a4d509639b7804214d057bca547cc3fafe509ec3e3a86321b1d1"}}},{"id":7645,"category":"researcher","content":"В разделе Group IM (сообщения сообществ, /al_im.php?gid=XXX) для почти всех действий (отправка сообщения, удаление диалога, etc) `hash` привязывался к `group_id`, и был одним и тем же для всех пользователей, которые имели доступ к личке этой группы. Таким образом, имея `hash` например к отправке сообщений, мы могли \"заманить\" другого редактора и выше (он имеет доступ к IM группы) на CSRF, и указаное нами сообщение отправится указанному peer_id от имени этого пользователя. Это timehash, и он живет около 7 часов, и после потери доступа к IM группы, использовать уязвимость уже было нельзя, но позже был найден способ получить статичный `hash`, что давало возможность использовать CSRF против этой группы, это можно использовать например как месть за снятие админки в группе. И еще `writeHash` сделали таймхешем.","updated_at":"2018-06-10T10:14:05.678Z","can_view?":true,"can_create?":false,"attachments":[],"user":{"id":82698,"username":"povargek","name":"","bio":"Farmer","cleared":false,"verified":false,"website":null,"location":"Phuket","created_at":"2016-06-03T11:04:58.744Z","url":"https://hackerone.com/povargek","hackerone_triager":false,"hackerone_employee":false,"user_type":"hacker","profile_picture_urls":{"small":"https://profile-photos.hackerone-user-content.com/variants/nS7rNaLQVwztSp3zfcDqNCHF/20fc426031f09e5347054871ae4e3af2478fd2b3d5e8a321468ecf6f2da5ac20","medium":"https://profile-photos.hackerone-user-content.com/variants/nS7rNaLQVwztSp3zfcDqNCHF/2b223a072c4b1b7ace4bb8e4a654ece8bf9e85dd759228c02857631ab0893a4b","xtralarge":"https://profile-photos.hackerone-user-content.com/variants/nS7rNaLQVwztSp3zfcDqNCHF/c03c144aff954b5f0f23d3bd8c235102a72528777fe4cb0d26990b4ccaa02fdc"}}}]}